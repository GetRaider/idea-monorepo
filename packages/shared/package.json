{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -b -v",
    "rebuild": "rm -rf dist && pnpm build",
    "clean": "rm -rf dist && rm -rf .turbo",
    "clean:hard": "pnpm run clean && rm -rf node_modules",
    "dev": "pnpm build --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "dependencies": {
    "pino": "^10.3.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@jest/globals": "catalog:",
    "@jest/types": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "ts-jest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:"
  }
}
