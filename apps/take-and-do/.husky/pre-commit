#!/usr/bin/env sh
set -e
cd "$(git rev-parse --show-toplevel)/apps/take-and-do" || exit 1
export PATH="$(pwd)/node_modules/.bin:$PATH"
pnpm exec pretty-quick --staged
pnpm exec tsc
if git diff --cached --name-only --diff-filter=ACM | grep -qE '^apps/take-and-do/.*\.(ts|tsx|js|jsx|mjs|cjs)$'; then
  pnpm exec lint-staged
fi
pnpm run test
