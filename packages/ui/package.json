{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -b -v",
    "dev": "tsc -b -v --watch",
    "clean": "rm -rf dist && rm -rf .turbo",
    "clean:hard": "pnpm run clean && rm -rf node_modules",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tailwind-preset": "./tailwind.preset.ts",
    "./assets/brands/take-and-do.svg": "./assets/brands/take-and-do.svg",
    "./*": "./src/*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "catalog:",
    "@types/eslint": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/styled-components": "catalog:",
    "eslint": "catalog:",
    "react": "catalog:",
    "tailwindcss": "^3.4.17",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@radix-ui/themes": "catalog:",
    "clsx": "^2.1.1",
    "styled-components": "catalog:",
    "tailwind-merge": "^3.5.0"
  }
}
