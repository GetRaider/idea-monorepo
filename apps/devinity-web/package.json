{
  "name": "devinity-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next && rm -rf .turbo",
    "clean:hard": "pnpm run clean && rm -rf node_modules",
    "build": "next build --turbopack",
    "dev": "NODE_ENV=development next dev --port 3001",
    "prod": "NODE_ENV=production next start --port 10000",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "@repo/api": "workspace:*",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "styled-components": "catalog:",
    "@radix-ui/react-icons": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@radix-ui/themes": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@stackframe/react": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "eslint-config-next": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "typescript": "catalog:",
    "@next/eslint-plugin-next": "catalog:",
    "@playwright/test": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/styled-components": "catalog:",
    "vitest": "catalog:",
    "typed-css-modules": "catalog:",
    "@tanstack/react-query-devtools": "catalog:"
  }
}
