{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env"],
  "globalEnv": [
    "AI_API_KEY",
    "AI_BASE_URL",
    "AI_MODEL",
    "AI_PROVIDER",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "DB_CONNECTION_STRING",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "LOG_LEVEL",
    "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
    "NEXT_PUBLIC_MIXPANEL_TOKEN",
    "NEXT_PUBLIC_WHITELIST_CONTACT_EMAIL",
    "NEXT_PUBLIC_PORTFOLIO_CONTACT_EMAIL",
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "clean": {
      "inputs": ["^clean"],
      "outputs": ["dist/**", ".next/**", ".turbo/**"]
    },
    "clean:hard": {
      "inputs": ["^clean:hard"],
      "outputs": ["dist/**", ".next/**", ".turbo/**", ".node_modules/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "tsconfig.build.tsbuildinfo",
        "dist/**"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV=development"],
      "cache": false,
      "persistent": true
    },
    "dev:devinity": {
      "inputs": ["^dev:devinity"],
      "env": ["NODE_ENV=development"],
      "cache": false,
      "persistent": true
    },
    "dev:take-and-do": {
      "inputs": ["^dev:take-and-do"],
      "env": ["NODE_ENV=development"],
      "cache": false,
      "persistent": true
    },
    "dev:portfolio": {
      "inputs": ["^dev:portfolio"],
      "env": ["NODE_ENV=development"],
      "cache": false,
      "persistent": true
    },
    "prod": {
      "env": ["NODE_ENV=production"],
      "dependsOn": ["build"],
      "cache": true,
      "persistent": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "codeCheck": {
      "dependsOn": ["^codeCheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"],
      "cache": false
    }
  }
}
